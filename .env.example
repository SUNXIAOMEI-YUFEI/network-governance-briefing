# AI 评分 LLM 配置
# 复制一份到 .env（不提交 git），填入真实值

# ---- OpenAI 兼容端点（OpenRouter / chr1 中转 / Claude 原生都行）----
LLM_API_KEY=sk-xxx-填你的-key
LLM_BASE_URL=https://pro.chr1.com/v1

# 要用的具体模型（中转站通常支持 OpenRouter 全套命名）
# 推荐：anthropic/claude-3.5-sonnet 或 anthropic/claude-sonnet-4
# 也可：openai/gpt-4o-mini（便宜但质量一般）
LLM_MODEL=anthropic/claude-3.5-sonnet

# 并发数 & 重试
LLM_CONCURRENCY=4
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SEC=60
